rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Хэрэглэгч өөрийн профайлыг унших/бичих боломжтой
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Асуултуудыг бүх нэвтэрсэн хэрэглэгч унших боломжтой
    // Зөвхөн admin бичих/устгах боломжтой
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email == "YOUR_ADMIN_EMAIL@domain.com";
        // ↑ Энд өөрийн admin имэйлийг оруулна уу
    }
  }
}
